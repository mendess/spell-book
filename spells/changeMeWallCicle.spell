#!/bin/bash
# Runs `changeMeWall` every 5 minutes

CACHE="/tmp/$LOGNAME"
mkdir -p "$CACHE"
while :; do
    while :; do
        [ -e "$CACHE/stop_wall" ] && continue
        read -r pape
        changeMeWall --wait-for-colors "$pape" "$@" &
        sleep 5m
        wait
    done < <(find "$WALLPAPERS" -type f | shuf)
done
